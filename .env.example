# FinanceIQ - Environment Configuration

# ── Database ─────────────────────────────────────────
DATABASE_URL=postgresql://postgres:password@localhost:5432/financeiq

# ── JWT Security ─────────────────────────────────────
SECRET_KEY=change-me-in-production-use-long-random-string
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ── CORS ─────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# ── AI / LLM (Virtual CFO) ───────────────────────────
# Option 1: OpenRouter (Recommended)
OPENAI_API_KEY=sk-or-v1-your-openrouter-key-here
OPENAI_MODEL=openai/gpt-4o-mini

# Option 2: OpenAI Direct
# OPENAI_API_KEY=sk-your-openai-key-here
# OPENAI_MODEL=gpt-4o-mini

# Available Models (OpenRouter):
# - openai/gpt-4o-mini (Budget, ~₹0.025/chat)
# - openai/gpt-4o (Premium, ~₹0.42/chat)
# - anthropic/claude-3.5-sonnet (Premium, ~₹0.50/chat)
# - google/gemini-2.0-flash-exp (Free tier available)

# Get OpenRouter key: https://openrouter.ai/keys
# Get OpenAI key: https://platform.openai.com/api-keys
